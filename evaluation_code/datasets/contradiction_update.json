{
  "dataset_name": "contradiction_update",
  "version": "1.0",
  "description": "Tests the memory engine's ability to handle contradictory and updating information. 20 test cases across 6 categories.",
  "test_cases": [
    {
      "test_id": "contradiction_001",
      "name": "Direct override: workspace number change",
      "category": "direct_override",
      "difficulty": "easy",
      "input": {
        "old": {
          "user_msg": "我的工位号是 A-305",
          "assistant_msg": "已记录，工位号：A-305。",
          "timestamp": "2026-04-01T10:00:00Z"
        },
        "new": {
          "user_msg": "我搬到新工位了，现在是 B-201",
          "assistant_msg": "已更新，工位号：B-201。旧工位 A-305 已归档。",
          "timestamp": "2026-05-01T10:00:00Z"
        },
        "query": "工位号",
        "max_results": 10
      },
      "expected": {
        "latest_value": "B-201",
        "old_value": "A-305",
        "expected_answer_contains": ["B-201", "A-305"]
      },
      "evaluation_criteria": {
        "latest_value_accuracy": {"target": 0.95, "min": 0.50},
        "history_preserved": {"target": 0.90},
        "min_chunks": 2
      }
    },
