        "alerts_generated": 2,
        "alert_timeliness_days": 16
      },
      "evaluation_criteria": {
        "alert_generation_rate": {"target": 0.90, "min": 0.60},
        "alert_timeliness": {"target": 0.90},
        "completeness": {"target": 0.85}
      }
    },
