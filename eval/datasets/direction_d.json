{
  "dataset_name": "direction_d",
  "version": "1.0",
  "description": "Tests the memory engine's ability to detect team knowledge gaps, provide forgetting reminders, sync team knowledge, and identify critical knowledge risks. 20 test cases across 5 categories.",
  "test_cases": [
    {
      "test_id": "direction_d_001",
      "name": "Knowledge gap detection: tech stack inconsistency",
      "category": "knowledge_gap_detection",
      "difficulty": "easy",
      "input": {
        "team_members": ["张三", "李四", "王五", "赵六"],
        "conversations": [
          {
            "user": "张三",
            "msg": "项目K使用 React + TypeScript 技术栈",
            "timestamp": "2026-04-01T10:00:00Z"
          },
          {
            "user": "张三",
            "msg": "项目K的部署用的是 AWS ECS",
            "timestamp": "2026-04-02T10:00:00Z"
          },
          {
            "user": "李四",
            "msg": "项目K的前端用的是 Vue",
            "timestamp": "2026-04-03T10:00:00Z"
          }
        ],
        "query": "团队对项目K的技术栈了解情况如何",
        "max_results": 10
      },
      "expected": {
        "expected_answer_contains": ["React", "Vue", "不一致", "冲突"],
        "expected_elements": [
          "张三了解前端技术栈（React）",
          "李四了解前端技术栈（Vue）——与张三认知不一致",
          "存在信息不一致"
        ],
        "knowledge_gaps_detected": 1,
        "conflicts_detected": 1
      },
      "evaluation_criteria": {
        "gap_detection_rate": {"target": 0.80, "min": 0.50},
        "conflict_identification": {"target": 0.85, "min": 0.50},
        "min_chunks": 2
      }
    },
    {
