    {
      "test_id": "kh_009",
      "name": "遗忘曲线-90天后回忆",
      "description": "90天前存储的知识，retention score应非常低，接近遗忘阈值",
      "setup": {
        "knowledge_entry": {
          "content": "去年Q1的技术评审结论：前端性能优化方案A",
          "stored_at": "2026-01-30T10:00:00",
          "recall_at": "2026-04-29T10:00:00",
          "reinforcements": 0
        }
      },
      "query": {"type": "retention_score", "entry_id": "kh_009"},
      "expected": {
        "retention_score": "< 0.3",
        "interval_days": 90,
        "curve_position": "near_forget"
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["forgetting-curve", "retention", "90-day"]
    },
    {
      "test_id": "kh_010",
      "name": "遗忘曲线-重复强化效果",
      "description": "同一条知识在7天内被重复强化3次，retention score应明显高于只存储1次的情况",
      "setup": {
        "knowledge_entries": [
          {
            "id": "kh_010a",
            "content": "团队Git工作流：feature branch → PR → review → merge",
            "stored_at": "2026-04-22T10:00:00",
            "reinforcements": 0
          },
          {
            "id": "kh_010b",
            "content": "团队Git工作流：feature branch → PR → review → merge",
            "stored_at": "2026-04-22T10:00:00",
            "reinforcements": 3,
            "reinforcement_dates": ["2026-04-24", "2026-04-26", "2026-04-28"]
          }
        ],
        "recall_at": "2026-04-29T10:00:00"
      },
      "query": {"type": "retention_comparison", "entry_ids": ["kh_010a", "kh_010b"]},
      "expected": {
        "kh_010a_retention": "0.6-0.8",
        "kh_010b_retention": ">= 0.9",
        "reinforcement_effect": true,
        "kh_010b_higher": true
      },
      "difficulty": "hard",
      "priority": "P0",
      "tags": ["forgetting-curve", "reinforcement", "comparison"]
    },
    {
      "test_id": "kh_011",
      "name": "知识缺口检测-全团队覆盖分析",
      "description": "团队有5个知识领域，但只有3个领域有知识记录。系统应识别出2个知识缺口领域",
      "setup": {
        "team_knowledge_coverage": {
          "required_domains": ["frontend", "backend", "devops", "database", "security"],
          "covered_domains": {
            "frontend": {"contributors": ["alice", "bob"], "entries": 15},
            "backend": {"contributors": ["charlie"], "entries": 8},
            "devops": {"contributors": ["dave", "eve"], "entries": 10}
          },
          "uncovered_domains": ["database", "security"]
        }
      },
      "query": {"type": "knowledge_gap_analysis", "team": "main_team"},
      "expected": {
        "gaps_found": ["database", "security"],
        "gap_count": 2,
        "coverage_rate": "60%",
        "risk_level": "high"
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["gap-detection", "team", "coverage"]
    },
    {
      "test_id": "kh_012",
      "name": "知识缺口检测-深度不足",
      "description": "某个领域有知识记录但条目很少（只有1条），说明深度不足。系统应区分'无覆盖'和'浅覆盖'",
      "setup": {
        "domain_analysis": {
          "domain": "security",
          "entries": [
            {"content": "使用HTTPS", "depth": "basic"}
          ],
          "expected_entries_for_adequate_depth": 10
        }
      },
      "query": {"type": "knowledge_depth_analysis", "domain": "security"},
      "expected": {
        "has_coverage": true,
        "depth_level": "shallow",
        "entries_count": 1,
        "required_for_adequate": 10,
        "gap_type": "depth_insufficient"
      },
      "difficulty": "medium",
      "priority": "P1",
      "tags": ["gap-detection", "depth", "quality"]
    },
