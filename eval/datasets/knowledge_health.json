        "context": "技术部刚完成React版本升级的决策记录",
        "knowledge_entry": {
          "content": "前端框架已升级到React 18.3，支持Concurrent Features",
          "created_at": "2026-04-26",
          "last_accessed": "2026-04-28",
          "access_count": 5
        },
        "current_time": "2026-04-29"
      },
      "query": {
        "text": "检测该知识的新鲜度状态",
        "type": "health_check"
      },
      "expected": {
        "freshness": "fresh",
        "age_days": 3,
        "confidence": ">= 0.95",
        "needs_refresh": false
      }
    },
