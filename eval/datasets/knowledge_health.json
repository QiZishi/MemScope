{
  "dataset_name": "knowledge_health",
  "version": "3.0",
  "description": "知识健康度评测：测试系统对知识新鲜度、遗忘曲线、知识缺口、单点故障、版本管理、多跳推理和知识关联网络的评估能力",
  "total_cases": 35,
  "difficulty_distribution": {
    "easy": 4,
    "medium": 14,
    "hard": 12,
    "expert": 5
  },
  "test_cases": [
    {
      "test_id": "kh_001",
      "name": "知识新鲜度-刚创建的知识(fresh)",
      "description": "3天前创建的知识条目，应该被标记为fresh（新鲜）。当前时间2026-04-29，知识创建于2026-04-26",
      "setup": {
        "knowledge_entry": {
          "content": "项目使用React 18 + TypeScript + Vite构建",
          "created_at": "2026-04-26",
          "last_accessed": "2026-04-28",
          "access_count": 5
        },
        "current_time": "2026-04-29"
      },
      "query": {"type": "health_check", "entry_id": "kh_001"},
      "expected": {
        "freshness": "fresh",
        "age_days": 3,
        "confidence": ">= 0.95",
        "needs_refresh": false
      },
      "difficulty": "easy",
      "priority": "P0",
      "tags": ["freshness", "fresh", "recent"]
    },
    {
      "test_id": "kh_002",
      "name": "知识新鲜度-开始老化的知识(aging)",
      "description": "20天前创建的知识条目，开始进入aging（老化）阶段。信息可能仍然有效但值得验证",
      "setup": {
        "knowledge_entry": {
          "content": "团队成员：张三(后端)、李四(前端)、王五(运维)",
          "created_at": "2026-04-09",
          "last_accessed": "2026-04-15",
          "access_count": 8
        },
        "current_time": "2026-04-29"
      },
      "query": {"type": "health_check", "entry_id": "kh_002"},
      "expected": {
        "freshness": "aging",
        "age_days": 20,
        "confidence": "0.7-0.9",
        "needs_refresh": false,
        "suggestion": "consider_verification"
      },
      "difficulty": "easy",
      "priority": "P0",
      "tags": ["freshness", "aging", "verification"]
    },
    {
      "test_id": "kh_003",
      "name": "知识新鲜度-过时的知识(stale)",
      "description": "60天前创建且未更新的知识条目，应标记为stale（过时）。很可能已经不准确",
      "setup": {
        "knowledge_entry": {
          "content": "生产环境部署在AWS us-east-1的EKS集群上",
          "created_at": "2026-02-28",
          "last_accessed": "2026-03-15",
          "access_count": 12
        },
        "current_time": "2026-04-29"
      },
      "query": {"type": "health_check", "entry_id": "kh_003"},
      "expected": {
        "freshness": "stale",
        "age_days": 60,
        "confidence": "0.4-0.7",
        "needs_refresh": true,
        "suggestion": "urgent_verification"
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["freshness", "stale", "outdated"]
    },
    {
      "test_id": "kh_004",
      "name": "知识新鲜度-已被遗忘的知识(forgotten)",
      "description": "120天前创建的知识，从未被访问过，应标记为forgotten（遗忘）。可能完全无效",
      "setup": {
        "knowledge_entry": {
          "content": "旧项目的数据库连接字符串：mysql://old-server:3306/app",
          "created_at": "2025-12-30",
          "last_accessed": null,
          "access_count": 0
        },
        "current_time": "2026-04-29"
      },
      "query": {"type": "health_check", "entry_id": "kh_004"},
      "expected": {
        "freshness": "forgotten",
        "age_days": 120,
        "confidence": "< 0.3",
        "needs_refresh": true,
        "suggestion": "archive_or_delete",
        "never_accessed": true
      },
      "difficulty": "medium",
      "priority": "P1",
      "tags": ["freshness", "forgotten", "never-accessed"]
    },
    {
      "test_id": "kh_005",
      "name": "知识新鲜度-频繁访问延缓老化",
      "description": "60天前创建的知识，但每天都在被访问。频繁访问应延缓老化速度，可能仍标记为aging而非stale",
      "setup": {
        "knowledge_entry": {
          "content": "API基础URL: https://api.example.com/v2",
          "created_at": "2026-02-28",
          "last_accessed": "2026-04-29",
          "access_count": 60,
          "access_frequency": "daily"
        },
        "current_time": "2026-04-29"
      },
      "query": {"type": "health_check", "entry_id": "kh_005"},
      "expected": {
        "freshness": "aging",
        "age_days": 60,
        "confidence": ">= 0.7",
        "needs_refresh": false,
        "freshness_boost_from_access": true
      },
      "difficulty": "hard",
      "priority": "P0",
      "tags": ["freshness", "access-boost", "aging-retardation"]
    },
    {
      "test_id": "kh_006",
      "name": "遗忘曲线-1天后回忆",
      "description": "1天前存储的知识，回忆时retention score应非常高（接近1.0）",
      "setup": {
        "knowledge_entry": {
          "content": "新同事赵六的邮箱是zhaoliu@example.com",
          "stored_at": "2026-04-28T10:00:00",
          "recall_at": "2026-04-29T10:00:00",
          "reinforcements": 1
        }
      },
      "query": {"type": "retention_score", "entry_id": "kh_006"},
      "expected": {
        "retention_score": ">= 0.9",
        "interval_days": 1,
        "curve_position": "high_retention"
      },
      "difficulty": "easy",
      "priority": "P0",
      "tags": ["forgetting-curve", "retention", "short-interval"]
    },
    {
      "test_id": "kh_007",
