{
  "dataset_name": "anti_interference",
  "version": "2.0",
  "description": "Tests the memory engine's ability to recall target information despite various noise patterns. 25 test cases across 6 categories including expert-level multi-hop and cross-type interference.",
  "total_cases": 25,
  "difficulty_distribution": {
    "easy": 4,
    "medium": 7,
    "hard": 9,
    "expert": 5
  },
  "test_cases": [
    {
      "test_id": "anti_interference_001",
      "name": "Single-round noise with 4 distractors",
      "category": "single_round_noise",
      "difficulty": "easy",
      "input": {
        "target": {
          "user_msg": "我下周三要去客户A公司做技术方案汇报",
          "assistant_msg": "好的，已记录。下周三（5月6日）客户A技术方案汇报。",
          "timestamp": "2026-05-01T10:00:00Z",
          "owner": "local"
        },
        "noise": [
          {"user_msg": "今天天气不错", "assistant_msg": "是的，天气很好。", "timestamp": "2026-05-01T10:05:00Z"},
          {"user_msg": "帮我订一杯拿铁咖啡", "assistant_msg": "已为您下单。", "timestamp": "2026-05-01T10:10:00Z"},
          {"user_msg": "最近有部新电影上映", "assistant_msg": "是的，您可以看看评分。", "timestamp": "2026-05-01T10:15:00Z"},
          {"user_msg": "明天要开会吗", "assistant_msg": "您明天上午10点有周会。", "timestamp": "2026-05-01T10:20:00Z"}
        ],
        "query": "客户A 技术方案汇报",
        "max_results": 10
      },
      "expected": {
        "expected_keywords": ["客户A", "技术方案汇报", "下周三"],
        "noise_keywords": ["天气", "拿铁", "电影"],
        "expected_answer_contains": ["客户A"]
      },
      "evaluation_criteria": {
        "recall": {"target": 0.90, "min": 0.50},
        "precision": {"target": 0.85, "min": 0.50},
        "noise_injection_rate": {"target": 0.05, "max": 0.10},
        "f1_score": {"target": 0.87, "min": 0.50},
        "min_chunks": 1
      }
    },
