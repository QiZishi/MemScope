{
  "dataset_name": "feishu_contradiction_update",
  "version": "1.0",
  "description": "矛盾信息更新评测（飞书企业场景）：测试系统对信息变更的识别和更新能力",
  "total_cases": 10,
  "test_cases": [
    {
      "test_id": "feishu_con_001",
      "name": "工位号变更",
      "difficulty": "easy",
      "category": "直接覆盖",
      "chunk": "2026年1月：我的工位号是A-305。2026年4月：我搬到新工位了，现在是B-201",
      "query": "我的工位号是多少？",
      "answer": "B-201",
      "expected_keywords": ["B-201"],
      "forbidden_keywords": ["A-305"]
    },
    {
      "test_id": "feishu_con_002",
      "name": "项目截止日期变更",
      "difficulty": "medium",
      "category": "直接覆盖",
