{
  "dataset_name": "long_term_memory",
  "version": "2.0",
  "description": "长时序记忆能力评测：专门测试3个月时间跨度下的记忆保持、信息覆盖废弃、重复强化和检索排序能力",
  "total_cases": 20,
  "difficulty_distribution": {
    "easy": 3,
    "medium": 10,
    "hard": 7
  },
  "test_cases": [
    {
      "test_id": "ltm_001",
      "name": "3个月对话回忆-团队决策",
      "description": "2026-01-15团队决定'使用Go重写核心服务'。到2026-04-29，搜索'核心服务重写'应仍能找到这条记录",
      "setup": {
        "conversation": {
          "date": "2026-01-15",
          "messages": [
            {"role": "user", "content": "核心服务用什么语言重写？Go还是Rust？", "timestamp": "2026-01-15T10:00:00"},
            {"role": "user", "content": "最终决定用Go，学习曲线更平缓，团队上手快", "timestamp": "2026-01-15T10:15:00"}
          ]
        },
        "query_time": "2026-04-29"
      },
      "query": {"type": "search", "keyword": "核心服务重写"},
      "expected": {
        "found": true,
        "content_keywords": ["Go", "重写", "核心服务"],
        "age_days": 104,
        "still_accessible": true
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["3-month", "recall", "decision"]
    },
    {
