{
  "dataset_name": "direction_a_cli_command_memory",
  "version": "1.0",
  "description": "CLI命令记忆评估数据集：测试高频命令识别、项目路径关联、前缀匹配推荐、上下文感知推荐四个维度的能力",
  "test_cases": [
    {
      "test_id": "cli_hf_01",
      "name": "高频Git命令识别",
      "description": "用户频繁使用git add/commit/push，应被识别为高频命令",
      "category": "high_frequency_command_identification",
      "difficulty": "easy",
      "commands": [
        {"command": "git add .", "exit_code": 0},
        {"command": "git commit -m 'fix'", "exit_code": 0},
        {"command": "git push origin main", "exit_code": 0},
        {"command": "git add .", "exit_code": 0},
        {"command": "git commit -m 'feat'", "exit_code": 0},
        {"command": "git push origin main", "exit_code": 0},
        {"command": "git add .", "exit_code": 0},
        {"command": "git commit -m 'chore'", "exit_code": 0},
        {"command": "git push origin main", "exit_code": 0},
        {"command": "git status", "exit_code": 0}
      ],
      "query": "用户最常用的命令是什么？",
      "expected": {
        "top_command": "git push origin main",
        "min_frequency": 3,
        "expected_commands": ["git add .", "git commit -m 'fix'", "git push origin main"]
      },
      "evaluation_criteria": {
        "recall_target": 0.9,
        "precision_target": 0.85,
        "f1_target": 0.87
      },
      "priority": "P0"
    },
    {
      "test_id": "cli_hf_02",
      "name": "Docker命令频率排序",
      "description": "用户在开发环境中频繁使用docker相关命令，应正确排序",
      "category": "high_frequency_command_identification",
      "difficulty": "medium",
      "commands": [
        {"command": "docker compose up -d", "exit_code": 0},
        {"command": "docker ps", "exit_code": 0},
        {"command": "docker logs app", "exit_code": 0},
        {"command": "docker compose up -d", "exit_code": 0},
        {"command": "docker ps", "exit_code": 0},
        {"command": "docker exec -it app bash", "exit_code": 0},
        {"command": "docker compose down", "exit_code": 0},
        {"command": "docker compose up -d", "exit_code": 0},
        {"command": "docker logs app", "exit_code": 0},
        {"command": "docker images", "exit_code": 0}
      ],
      "query": "列出使用频率最高的前3个docker命令",
      "expected": {
        "top_command": "docker compose up -d",
        "min_frequency": 3,
        "expected_commands": ["docker compose up -d", "docker ps", "docker logs app"]
