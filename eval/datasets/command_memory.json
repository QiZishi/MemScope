{
  "dataset_name": "command_memory",
  "version": "4.0",
  "description": "命令记忆能力评测（飞书企业场景）：测试系统对用户高频飞书操作的记录、频率统计、上下文关联、智能推荐、多跳推理、实体追踪和时序推理能力",
  "total_cases": 30,
  "difficulty_distribution": {
    "easy": 9,
    "medium": 15,
    "hard": 6
  },
  "test_cases": [
    {
      "test_id": "cmd_001",
      "name": "高频操作识别-多用户交叉",
      "description": "用户A高频使用飞书审批(8次)和日历(3次)；用户B高频使用多维表格(6次)和OKR(4次)。查询A的高频操作时不应包含多维表格或OKR，验证系统能正确区分不同用户的操作历史",
      "setup": {
        "user_a_operations": [
          {
            "operation": "提交请假审批",
            "count": 4
          },
          {
            "operation": "提交报销审批",
            "count": 4
          },
          {
            "operation": "创建会议",
            "count": 3
          }
        ],
        "user_b_operations": [
          {
            "operation": "创建多维表格",
            "count": 3
          },
          {
            "operation": "切换表格视图",
            "count": 3
          },
          {
            "operation": "更新OKR进度",
            "count": 4
          }
        ]
      },
      "query": {
        "user": "user_a",
        "type": "frequent"
      },
      "expected": {
        "top_operation": "审批",
        "min_frequency": 8,
        "must_not_contain": [
          "多维表格",
          "OKR"
        ],
        "expected_keywords": ["审批", "请假", "报销", "日历", "会议"]
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["飞书", "cross-user", "frequency", "isolation"]
    },
    {
      "test_id": "cmd_002",
      "name": "高频操作识别-均匀分布",
      "description": "用户C的5个飞书操作各使用了2次，频率完全相同。系统应返回全部5个操作并按某种稳定排序，不应遗漏任何一个",
      "setup": {
        "user_c_operations": [
          {
            "operation": "查看群聊消息",
            "count": 2
          },
          {
            "operation": "发送文档评论",
            "count": 2
          },
          {
            "operation": "创建任务",
            "count": 2
          },
          {
            "operation": "更新OKR进度",
            "count": 2
          },
          {
            "operation": "编辑知识库文档",
            "count": 2
          }
        ]
      },
      "query": {
        "user": "user_c",
        "type": "frequent",
        "limit": 5
      },
      "expected": {
        "all_operations_present": [
          "查看群聊消息",
          "发送文档评论",
          "创建任务",
          "更新OKR进度",
          "编辑知识库文档"
        ],
        "count_of_results": 5,
        "all_frequencies_equal": true,
        "expected_keywords": ["群聊", "消息", "评论", "文档", "任务", "OKR", "知识库"]
      },
      "difficulty": "easy",
      "priority": "P1",
      "tags": ["飞书", "frequency", "edge-case", "uniform-distribution"]
    },
    {
      "test_id": "cmd_003",
      "name": "高频操作识别-极端偏斜分布",
      "description": "用户D的操作历史中，查看飞书群聊消息出现了100次，其他操作各出现1次。验证系统能正确处理极端偏斜的频率分布，查看群聊消息应排第一",
      "setup": {
        "user_d_operations": [
          {
            "operation": "查看群聊消息",
            "count": 100
          },
          {
            "operation": "创建采购审批",
            "count": 1
          },
          {
            "operation": "编辑飞书文档",
            "count": 1
          },
          {
            "operation": "修改会议时间",
            "count": 1
          },
          {
            "operation": "创建OKR目标",
            "count": 1
          }
        ]
      },
      "query": {
        "user": "user_d",
        "type": "frequent",
        "limit": 3
      },
      "expected": {
        "rank_1": "查看群聊消息",
        "rank_1_frequency": 100,
        "rank_2_frequency": 1,
        "top_to_second_ratio": ">= 50",
        "expected_keywords": ["群聊", "消息", "采购", "审批", "文档", "会议", "OKR"]
      },
      "difficulty": "easy",
      "priority": "P1",
      "tags": ["飞书", "frequency", "edge-case", "skewed-distribution"]
    },
    {
      "test_id": "cmd_004",
      "name": "高频操作识别-时间衰减",
      "description": "用户E在3个月前大量使用旧版审批模板(20次)，最近1周大量使用飞书文档协作(15次)。如果系统支持时间加权，最近的文档协作应排名高于历史审批模板",
      "setup": {
        "user_e_operations": [
          {
            "operation": "使用旧版请假审批模板",
            "count": 10,
            "timestamp": "2026-01-15"
          },
          {
            "operation": "使用旧版报销审批模板",
            "count": 10,
            "timestamp": "2026-01-15"
          },
          {
            "operation": "创建飞书文档",
            "count": 8,
            "timestamp": "2026-04-25"
          },
          {
            "operation": "分享文档权限",
            "count": 7,
            "timestamp": "2026-04-26"
          }
        ],
        "query_time": "2026-04-29"
      },
      "query": {
        "user": "user_e",
        "type": "frequent",
        "time_weighted": true
      },
      "expected": {
        "top_operation": "文档",
        "doc_rank_higher_than_approval_template": true,
        "expected_keywords": ["文档", "创建", "分享", "权限"]
      },
      "difficulty": "easy",
      "priority": "P0",
      "tags": ["飞书", "frequency", "temporal", "time-decay"]
    },
    {
      "test_id": "cmd_005",
      "name": "高频操作识别-新用户无历史",
      "description": "用户F是新用户，没有任何飞书操作历史。系统应返回空列表或明确提示无数据，不应报错或返回其他用户的数据",
      "setup": {
        "existing_users": {
          "user_a_operations": [
            {
              "operation": "提交请假审批",
              "count": 10
            }
          ]
        },
        "new_user": "user_f"
      },
      "query": {
        "user": "user_f",
        "type": "frequent"
      },
      "expected": {
        "result": "empty",
        "must_not_contain": [
          "请假审批"
        ],
        "error": false,
        "expected_keywords": []
      },
      "difficulty": "easy",
      "priority": "P0",
      "tags": ["飞书", "frequency", "edge-case", "empty-history"]
    },
    {
      "test_id": "cmd_006",
      "name": "高频操作识别-含复杂操作描述",
      "description": "用户G的操作中包含复杂描述：带人名@提及、带附件、带审批金额等。系统应正确记录和统计这些含特殊信息的操作",
      "setup": {
        "user_g_operations": [
          {
            "operation": "在「产品需求讨论群」@张三 发送消息并附带飞书文档链接",
            "count": 5
          },
          {
            "operation": "提交报销审批（金额¥12,500.00，附件3张发票）",
            "count": 3
          },
          {
            "operation": "创建会议「Q2产品评审 | 14:00-15:30」邀请8人",
            "count": 2
          }
        ]
      },
      "query": {
        "user": "user_g",
        "type": "frequent"
      },
      "expected": {
        "top_operation": "群聊消息",
        "all_operations_preserved": true,
        "special_chars_intact": true,
        "expected_keywords": ["群聊", "消息", "@", "文档", "报销", "审批", "会议", "评审"]
      },
      "difficulty": "medium",
      "priority": "P1",
      "tags": ["飞书", "frequency", "special-chars", "edge-case"]
    },
    {
      "test_id": "cmd_007",
      "name": "业务模块关联-同用户多模块",
      "description": "用户H在「人事行政部」空间中使用请假/报销审批，在「产品研发部」空间中使用任务管理和代码评审文档。查询人事行政部的操作应只返回审批相关",
      "setup": {
        "user_h_operations": [
          {
            "operation": "提交请假审批",
            "space": "人事行政部",
            "count": 5
          },
          {
            "operation": "提交报销审批",
            "space": "人事行政部",
            "count": 3
          },
          {
            "operation": "审批采购申请",
            "space": "人事行政部",
            "count": 2
          },
          {
