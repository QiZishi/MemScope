        "space_specific": true,
        "expected_keywords": ["请假", "审批", "报销", "采购", "人事", "行政"]
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": ["飞书", "space", "cross-module", "isolation"]
    },
    {
      "test_id": "cmd_008",
      "name": "业务模块关联-嵌套空间",
