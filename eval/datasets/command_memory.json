        "user_t_recent_sequence": [
          {
            "command": "git add .",
            "timestamp": "2026-04-29T10:00:00"
          },
          {
            "command": "git status",
            "timestamp": "2026-04-29T10:01:00"
          },
          {
            "command": "git commit -m \"feature\"",
            "timestamp": "2026-04-29T10:02:00"
          }
        ],
        "user_t_history": [
          {
            "command": "git add .",
            "count": 20
          },
          {
            "command": "git status",
            "count": 18
          },
          {
            "command": "git commit -m",
            "count": 17
          },
          {
            "command": "git push",
            "count": 16
          }
        ]
      },
      "query": {
        "user": "user_t",
        "type": "context_recommend",
