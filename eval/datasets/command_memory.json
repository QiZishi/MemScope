{
  "dataset_name": "command_memory",
  "version": "3.0",
  "description": "命令记忆能力评测：测试系统对用户历史命令的记录、频率统计、上下文关联、智能推荐、多跳推理、实体追踪和时序推理能力",
  "total_cases": 37,
  "difficulty_distribution": {
    "easy": 6,
    "medium": 13,
    "hard": 11,
    "expert": 7
  },
  "test_cases": [
    {
      "test_id": "cmd_001",
      "name": "高频命令识别-多用户交叉",
      "description": "用户A高频使用git(8次), docker(3次); 用户B高频使用npm(6次), node(4次). 查询A的高频命令时不应包含npm或node，验证系统能正确区分不同用户的命令历史",
      "setup": {
        "user_a_commands": [
          {
            "command": "git status",
            "count": 4
          },
          {
            "command": "git commit",
            "count": 4
          },
          {
            "command": "docker build",
            "count": 3
          }
        ],
        "user_b_commands": [
          {
            "command": "npm install",
            "count": 3
          },
          {
            "command": "npm test",
            "count": 3
          },
          {
            "command": "node server.js",
            "count": 4
          }
        ]
      },
      "query": {
        "user": "user_a",
        "type": "frequent"
      },
      "expected": {
        "top_command": "git",
        "min_frequency": 8,
        "must_not_contain": [
          "npm",
          "node"
        ]
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": [
        "cross-user",
        "frequency",
        "isolation"
      ]
    },
    {
      "test_id": "cmd_002",
      "name": "高频命令识别-均匀分布",
      "description": "用户C的5个命令各使用了2次，频率完全相同。系统应返回全部5个命令并按某种稳定排序，不应遗漏任何一个",
      "setup": {
        "user_c_commands": [
          {
            "command": "ls -la",
            "count": 2
          },
          {
            "command": "cd /home",
            "count": 2
          },
          {
            "command": "cat README.md",
            "count": 2
          },
          {
            "command": "grep error",
            "count": 2
          },
          {
            "command": "tail -f log",
            "count": 2
          }
        ]
      },
      "query": {
        "user": "user_c",
        "type": "frequent",
        "limit": 5
      },
      "expected": {
        "all_commands_present": [
          "ls -la",
          "cd /home",
          "cat README.md",
          "grep error",
          "tail -f log"
        ],
        "count_of_results": 5,
        "all_frequencies_equal": true
      },
      "difficulty": "easy",
      "priority": "P1",
      "tags": [
        "frequency",
        "edge-case",
        "uniform-distribution"
      ]
    },
    {
      "test_id": "cmd_003",
      "name": "高频命令识别-极端偏斜分布",
      "description": "用户D的命令历史中，git status出现了100次，其他命令各出现1次。验证系统能正确处理极端偏斜的频率分布，git status应排第一",
      "setup": {
        "user_d_commands": [
          {
            "command": "git status",
            "count": 100
          },
          {
            "command": "vim config.yaml",
            "count": 1
          },
          {
            "command": "python test.py",
            "count": 1
          },
          {
            "command": "ssh deploy@server",
            "count": 1
          },
          {
            "command": "curl localhost:8080",
            "count": 1
          }
        ]
      },
      "query": {
        "user": "user_d",
        "type": "frequent",
        "limit": 3
      },
      "expected": {
        "rank_1": "git status",
        "rank_1_frequency": 100,
        "rank_2_frequency": 1,
        "top_to_second_ratio": ">= 50"
      },
      "difficulty": "easy",
      "priority": "P1",
      "tags": [
        "frequency",
        "edge-case",
        "skewed-distribution"
      ]
    },
    {
      "test_id": "cmd_004",
      "name": "高频命令识别-时间衰减",
      "description": "用户E在3个月前大量使用svn(20次)，最近1周大量使用git(15次)。如果系统支持时间加权，最近的git应排名高于历史svn",
      "setup": {
        "user_e_commands": [
          {
            "command": "svn update",
            "count": 10,
            "timestamp": "2026-01-15"
          },
          {
            "command": "svn commit",
            "count": 10,
            "timestamp": "2026-01-15"
          },
          {
            "command": "git pull",
            "count": 8,
            "timestamp": "2026-04-25"
          },
          {
            "command": "git push",
            "count": 7,
            "timestamp": "2026-04-26"
          }
        ],
        "query_time": "2026-04-29"
      },
      "query": {
        "user": "user_e",
        "type": "frequent",
        "time_weighted": true
      },
      "expected": {
        "top_command": "git",
        "git_rank_higher_than_svn": true
      },
      "difficulty": "hard",
      "priority": "P0",
      "tags": [
        "frequency",
        "temporal",
        "time-decay"
      ]
    },
    {
      "test_id": "cmd_005",
      "name": "高频命令识别-新用户无历史",
      "description": "用户F是新用户，没有任何命令历史。系统应返回空列表或明确提示无数据，不应报错或返回其他用户的数据",
      "setup": {
        "existing_users": {
          "user_a_commands": [
            {
              "command": "git status",
              "count": 10
