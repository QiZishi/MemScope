        "empty-history"
      ]
    },
    {
      "test_id": "cmd_006",
      "name": "高频命令识别-含特殊字符命令",
      "description": "用户G的命令中包含特殊字符：管道符、重定向、引号等。系统应正确记录和统计这些含特殊字符的命令",
      "setup": {
        "user_g_commands": [
          {
            "command": "cat log.txt | grep ERROR | wc -l",
            "count": 5
          },
          {
            "command": "echo \"hello world\" > output.txt",
            "count": 3
          },
          {
            "command": "find . -name '*.py' -exec grep TODO {} \\;",
            "count": 2
          }
        ]
      },
      "query": {
        "user": "user_g",
        "type": "frequent"
      },
      "expected": {
        "top_command": "cat log.txt | grep ERROR | wc -l",
        "all_commands_preserved": true,
        "special_chars_intact": true
      },
      "difficulty": "medium",
      "priority": "P1",
      "tags": [
        "frequency",
        "special-chars",
        "edge-case"
      ]
    },
    {
      "test_id": "cmd_007",
      "name": "项目路径关联-同用户多项目",
      "description": "用户H在项目A(/home/h/projectA)中使用npm/yarn命令，在项目B(/home/h/projectB)中使用python/pip命令。查询项目A的命令应只返回npm/yarn相关",
      "setup": {
        "user_h_commands": [
          {
            "command": "npm install",
            "path": "/home/h/projectA",
            "count": 5
          },
          {
            "command": "npm test",
            "path": "/home/h/projectA",
            "count": 3
          },
          {
            "command": "yarn build",
            "path": "/home/h/projectA",
            "count": 2
          },
          {
            "command": "pip install django",
            "path": "/home/h/projectB",
            "count": 4
          },
          {
            "command": "python manage.py runserver",
            "path": "/home/h/projectB",
            "count": 6
          }
        ]
      },
      "query": {
        "user": "user_h",
        "type": "project_commands",
        "project": "/home/h/projectA"
      },
      "expected": {
        "commands_in_result": [
          "npm install",
          "npm test",
          "yarn build"
        ],
        "must_not_contain": [
          "pip install django",
          "python manage.py runserver"
        ],
        "project_specific": true
      },
      "difficulty": "medium",
      "priority": "P0",
      "tags": [
        "project-path",
        "cross-user",
        "isolation"
      ]
    },
    {
      "test_id": "cmd_008",
